{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 20,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "default",
            "hidden": true,
            "binaryDir": "${sourceDir}/build/${presetName}"
        },
        {
            "name": "windows-default",
            "hidden": true,
            "inherits": "default",
            "generator": "Visual Studio 17 2022",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "linux-default",
            "hidden": true,
            "inherits": "default",
            "generator": "Unix Makefiles",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            }
        },
        {
            "name": "debug",
            "displayName": "Debug (Windows)",
            "inherits": "windows-default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "release",
            "displayName": "Release (Windows)",
            "inherits": "windows-default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "linux-debug",
            "displayName": "Debug (Linux)",
            "inherits": "linux-default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "linux-release",
            "displayName": "Release (Linux)",
            "inherits": "linux-default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "debug-simloss",
            "displayName": "Debug + Simulated Loss (Windows)",
            "inherits": "debug",
            "cacheVariables": {
                "ENTANGLEMENT_SIMULATE_LOSS": "ON"
            }
        },
        {
            "name": "release-simloss",
            "displayName": "Release + Simulated Loss (Windows)",
            "inherits": "release",
            "cacheVariables": {
                "ENTANGLEMENT_SIMULATE_LOSS": "ON"
            }
        },
        {
            "name": "linux-debug-simloss",
            "displayName": "Debug + Simulated Loss (Linux)",
            "inherits": "linux-debug",
            "cacheVariables": {
                "ENTANGLEMENT_SIMULATE_LOSS": "ON"
            }
        },
        {
            "name": "linux-release-simloss",
            "displayName": "Release + Simulated Loss (Linux)",
            "inherits": "linux-release",
            "cacheVariables": {
                "ENTANGLEMENT_SIMULATE_LOSS": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "debug",
            "displayName": "Debug (Windows)",
            "configurePreset": "debug",
            "configuration": "Debug"
        },
        {
            "name": "release",
            "displayName": "Release (Windows)",
            "configurePreset": "release",
            "configuration": "Release"
        },
        {
            "name": "linux-debug",
            "displayName": "Debug (Linux)",
            "configurePreset": "linux-debug"
        },
        {
            "name": "linux-release",
            "displayName": "Release (Linux)",
            "configurePreset": "linux-release"
        },
        {
            "name": "debug-simloss",
            "displayName": "Debug + Simulated Loss (Windows)",
            "configurePreset": "debug-simloss",
            "configuration": "Debug"
        },
        {
            "name": "release-simloss",
            "displayName": "Release + Simulated Loss (Windows)",
            "configurePreset": "release-simloss",
            "configuration": "Release"
        },
        {
            "name": "linux-debug-simloss",
            "displayName": "Debug + Simulated Loss (Linux)",
            "configurePreset": "linux-debug-simloss"
        },
        {
            "name": "linux-release-simloss",
            "displayName": "Release + Simulated Loss (Linux)",
            "configurePreset": "linux-release-simloss"
        }
    ]
}
